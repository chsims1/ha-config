# Secrets — never commit these
secrets.yaml

# Internal HA runtime state (tokens, registries, UI-created helpers)
.storage/
.cloud/
.HA_VERSION
.ha_run.lock

# Databases
*.db
*.db-shm
*.db-wal

# Logs
*.log
*.log.*

# Python cache
__pycache__/
deps/

# ESPHome manages its own internal git repo — don't track it here
esphome/
# HA's own generated icon cache — not source, regenerates automatically
.cache/

# HACS-managed custom integrations — HACS owns these, don't duplicate here
custom_components/